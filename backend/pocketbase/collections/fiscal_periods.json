{
  "name": "fiscal_periods",
  "type": "base",
  "system": false,
  "schema": [
    { "name": "tenantId", "type": "text", "required": true },
    { "name": "label", "type": "text", "required": true },
    { "name": "year", "type": "text", "required": true },
    { "name": "period", "type": "text", "required": true },
    { "name": "status", "type": "select", "required": true, "options": { "values": ["Open", "Soft Close", "Hard Close"] } }
  ],
  "listRule": "tenantId = @request.auth.tenantId || @request.auth.role = 'admin'",
  "viewRule": "tenantId = @request.auth.tenantId || @request.auth.role = 'admin'",
  "createRule": "@request.auth.role = 'admin'",
  "updateRule": "@request.auth.role = 'admin'",
  "deleteRule": "@request.auth.role = 'admin'"
}
